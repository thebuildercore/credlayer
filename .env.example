# Blockchain Configuration
# Your Ethereum wallet private key (WITHOUT the 0x prefix)
# SECURITY WARNING: Never commit this file with real values! Keep .env in .gitignore
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# 0G Network RPC URL (default for Galileo testnet)
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Compute Configuration
# AI Provider address for inference
PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836

# 0G Storage Configuration
STORAGE_RPC_URL=https://rpc-storage-testnet.0g.ai

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here
